<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <title>星空雷霆 - 经典打飞机</title>
    <style>
        body { margin: 0; background: #050505; color: white; overflow: hidden; font-family: 'Arial', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; }
        canvas { background: linear-gradient(to bottom, #000428, #004e92); border: 2px solid #333; box-shadow: 0 0 20px rgba(0,255,255,0.2); cursor: none; }
        #ui { position: absolute; top: 20px; left: 20px; pointer-events: none; }
        .score { font-size: 24px; color: #00f2ff; text-shadow: 0 0 10px #00f2ff; }
    </style>
</head>
<body>

    <div id="ui"><div class="score">分数: <span id="scoreVal">0</span></div></div>
    <canvas id="gameCanvas"></canvas>

<script>
    const canvas = document.getElementById("gameCanvas");
    const ctx = canvas.getContext("2d");
    const scoreEl = document.getElementById("scoreVal");

    canvas.width = 400;
    canvas.height = 600;

    let score = 0;
    let gameActive = true;

    // 1. 玩家飞机对象
    const player = {
        x: canvas.width / 2 - 15,
        y: canvas.height - 60,
        w: 40,
        h: 40,
        color: "#00f2ff"
    };

    const bullets = [];
    const enemies = [];

    // 2. 监听鼠标/触摸移动飞机
    canvas.addEventListener("mousemove", (e) => {
        const rect = canvas.getBoundingClientRect();
        player.x = e.clientX - rect.left - player.w / 2;
        // 限制边界
        if (player.x < 0) player.x = 0;
        if (player.x > canvas.width - player.w) player.x = canvas.width - player.w;
    });

    // 3. 自动发射子弹
    setInterval(() => {
        if (gameActive) {
            bullets.push({ x: player.x + player.w / 2 - 2, y: player.y, w: 4, h: 10, speed: 7 });
        }
    }, 200);

    // 4. 生成敌人
    function spawnEnemy() {
        if (!gameActive) return;
        const size = Math.random() * 30 + 20;
        enemies.push({
            x: Math.random() * (canvas.width - size),
            y: -size,
            w: size,
            h: size,
            speed: Math.random() * 2 + 2,
            hp: Math.floor(size / 10)
        });
        setTimeout(spawnEnemy, Math.random() * 1000 + 500);
    }
    spawnEnemy();

    // 5. 核心循环
    function update() {
        if (!gameActive) return;

        // 清屏
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // 绘制玩家 (简单的三角形飞机)
        ctx.fillStyle = player.color;
        ctx.shadowBlur = 15; ctx.shadowColor = player.color;
        ctx.beginPath();
        ctx.moveTo(player.x + player.w/2, player.y);
        ctx.lineTo(player.x, player.y + player.h);
        ctx.lineTo(player.x + player.w, player.y + player.h);
        ctx.fill();

        // 处理子弹
        bullets.forEach((b, bi) => {
            b.y -= b.speed;
            ctx.fillStyle = "#fff";
            ctx.fillRect(b.x, b.y, b.w, b.h);
            if (b.y < 0) bullets.splice(bi, 1);
        });

        // 处理敌人
        enemies.forEach((e, ei) => {
            e.y += e.speed;
            ctx.fillStyle = "#ff4757";
            ctx.shadowColor = "#ff4757";
            ctx.fillRect(e.x, e.y, e.w, e.h);

            // 碰撞检测: 子弹打中敌人
            bullets.forEach((b, bi) => {
                if (b.x < e.x + e.w && b.x + b.w > e.x && b.y < e.y + e.h && b.y + b.h > e.y) {
                    bullets.splice(bi, 1);
                    e.hp--;
                    if (e.hp <= 0) {
                        enemies.splice(ei, 1);
                        score += 10;
                        scoreEl.innerText = score;
                    }
                }
            });

            // 碰撞检测: 敌人撞击玩家
            if (e.x < player.x + player.w && e.x + e.w > player.x && e.y < player.y + player.h && e.y + e.h > player.y) {
                gameOver();
            }

            if (e.y > canvas.height) enemies.splice(ei, 1);
        });

        requestAnimationFrame(update);
    }

    function gameOver() {
        gameActive = false;
        alert("战机坠毁！你的得分: " + score);
        location.reload();
    }

    update();
</script>
</body>
</html>
